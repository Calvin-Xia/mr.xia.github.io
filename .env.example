# ===== Obsidian 文章发布管线配置 =====
# 复制本文件为 .env，填入实际值
# WARNING: .env 已加入 .gitignore，切勿提交

# Astro canonical site URL（一次构建只应配置一个主域名）
BASE_URL=https://calvin-xia.cn

# Obsidian Vault 工作区绝对路径
OKP_VAULT=C:\path\to\your\ObsidianVault

# Cloudflare R2 S3 兼容 API
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=assets-of-my-blogs
R2_PUBLIC_URL=https://content.calvin-xia.cn

# ===== /new-post/ 表单页面鉴权 =====
NEW_POST_SECRET=your-secret-here-change-me

# 额外允许调用本地 new-post API 的精确 Origin，多个用英文逗号分隔。
# 默认已允许 localhost / 127.0.0.1 / calvin-xia.cn / www.calvin-xia.cn / origin.calvin-xia.cn /
# https://mr-xia-site.calvin-xia.workers.dev。
# 如需保留 Cloudflare Workers 原链接，请填完整 origin，不要使用通配符。
NEW_POST_ALLOWED_ORIGINS=https://your-worker-name.your-account.workers.dev

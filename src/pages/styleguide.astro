---
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="样式指南 - Mr.Xia" description="Mr.Xia 网站样式指南">
    <PageIntro title="样式指南" subtitle="本页面展示网站的设计元素和规范" compact />

    <section class="section-stack">
        <h2>色彩系统</h2>
        <div class="styleguide-grid">
            <div class="token-card token-card--primary">
                <div>主色</div>
                <small>#d35d26</small>
            </div>
            <div class="token-card token-card--secondary">
                <div>辅色</div>
                <small>#c86681</small>
            </div>
            <div class="token-card token-card--accent">
                <div>强调色</div>
                <small>#2f8f83</small>
            </div>
        </div>
    </section>

    <section class="section-stack">
        <h2>排版系统</h2>
        <div class="card">
            <h1>这是一级标题 H1</h1>
            <h2>这是二级标题 H2</h2>
            <h3>这是三级标题 H3</h3>
            <p>这是一段正文。使用系统默认字体，行高确保良好的可读性。</p>
            <p class="text-small">这是小号文本，用于次要信息展示。</p>
        </div>
    </section>

    <section class="section-stack">
        <h2>按钮样式</h2>
        <div class="card">
            <div class="action-row">
                <button class="btn">主要按钮</button>
                <button class="btn btn-secondary">次要按钮</button>
                <button class="btn btn-outline">轮廓按钮</button>
            </div>
        </div>
    </section>

    <section class="section-stack">
        <h2>卡片样式</h2>
        <div class="card">
            <h3>普通卡片</h3>
            <p>这是一个标准的卡片组件，包含标题和正文，悬停时会有平滑的阴影变化效果。</p>
        </div>

        <div class="shadowbox">
            <h3>阴影盒</h3>
            <p>这是一个带有特殊装饰效果的阴影盒组件，顶部有渐变动画效果。</p>
        </div>
    </section>

    <section class="section-stack">
        <h2>时间组件</h2>
        <div class="card">
            <h3>时间显示</h3>
            <div id="currentTime" class="current-time">加载中...</div>
        </div>
    </section>

    <section class="section-stack">
        <h2>链接样式</h2>
        <div class="card">
            <p>
                这是一个 <a href="#">标准链接</a>，带有悬停效果。
            </p>
        </div>
    </section>

    <section class="section-stack">
        <h2>间距系统</h2>
        <div class="section-stack">
            <div class="card-note">xs - 0.5rem</div>
            <div class="card-note">sm - 1rem</div>
            <div class="card-note">md - 1.5rem</div>
            <div class="card-note">lg - 2rem</div>
            <div class="card-note">xl - 3rem</div>
        </div>
    </section>

    <div class="page-return">
        <a href="/" class="btn btn-secondary" data-history="true" data-title="首页">
            返回首页
        </a>
    </div>
</BaseLayout>

<script>
    import { initButtonRipples, PageAnimations } from '../scripts/page-animations';
    import { TimeDisplay } from '../scripts/time-display';

    function safeInit(moduleName: string, initFn: () => void): void {
        try {
            initFn();
        } catch (error) {
            console.error(`[模块初始化错误] ${moduleName}:`, error);
        }
    }

    function initStyleguidePage(): void {
        safeInit('TimeDisplay', () => TimeDisplay.init());
        safeInit('PageAnimations', () => PageAnimations.init());
        safeInit('ButtonRipples', initButtonRipples);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initStyleguidePage, { once: true });
    } else {
        initStyleguidePage();
    }
</script>

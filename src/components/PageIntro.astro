---
interface Props {
    kicker?: string;
    title: string;
    subtitle?: string;
    center?: boolean;
    compact?: boolean;
}

const { kicker, title, subtitle, center = false, compact = false } = Astro.props;

const classes = [
    'page-intro',
    center ? 'page-intro--center' : '',
    compact ? 'page-intro--compact' : '',
]
    .filter(Boolean)
    .join(' ');
---

<section class={classes}>
    {kicker && <p class="section-kicker">{kicker}</p>}
    <h1 class="page-title">{title}</h1>
    {subtitle && <p class="page-subtitle">{subtitle}</p>}
</section>
